# ═══════════════════════════════════════════════════════════
# uni.id — Frontend Expo (.env.local)
# Copiá este archivo como .env.local
# ═══════════════════════════════════════════════════════════

# URL del backend — IMPORTANTE:
#
# En la web (navegador en la misma PC): dejar vacío usa http://localhost:8080/api
#
# En celular con Expo Go (misma red WiFi):
#   1. Corré en la terminal: ipconfig (Windows) o ifconfig (Mac/Linux)
#   2. Fijate tu IP local, por ejemplo: 192.168.1.50
#   3. Descomentá y completá la línea de abajo:
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8080/api

# Para producción (Railway, Render, etc.):
# EXPO_PUBLIC_API_URL=https://tu-backend.up.railway.app/api
